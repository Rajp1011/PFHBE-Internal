	</WINCOMB>

<!-- Reels configuration  <PROB Symb="120 160 280 320 360 120 " /> -->

	<REELS Type="Prob" TotalProb="1" TotalSymbIds="6" FreqSizes="6">
	<Set reel="0 0 0 0 0 0 0 0 0"/>
	<PROB Symb="120 160 280 320 360 120 " />
	</REELS>

<!--	FREEGAME -->
	<FREEGAME Id="1" Prize="0,5,7,10,15" Prob="9800,70,70,40,20"/>

<SKILLS_SCALE min="0" max="110" step="5">
</SKILLS_SCALE>

<SKILL_BONUS id="1" tag="TSB">
</SKILL_BONUS >
</SLOT>

